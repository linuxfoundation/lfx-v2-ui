# Environment Configuration
ENV=development
NODE_ENV=development
PORT=4200
PCC_BASE_URL=http://localhost:4200

# Auth0 Authentication Configuration
# Get these values from 1Password (LFX One Dev Environment vault)
PCC_AUTH0_CLIENT_ID=your-auth0-client-id
PCC_AUTH0_CLIENT_SECRET=your-auth0-client-secret
PCC_AUTH0_ISSUER_BASE_URL=your-auth0-issuer-url
PCC_AUTH0_AUDIENCE=your-auth0-audience
PCC_AUTH0_SECRET=sufficiently-long-random-string

# M2M Token Generation
# Get these values from 1Password (LFX One Dev Environment vault)
M2M_AUTH_CLIENT_ID=your-m2m-client-id
M2M_AUTH_CLIENT_SECRET=your-m2m-client-secret
M2M_AUTH_ISSUER_BASE_URL=your-m2m-issuer-url
M2M_AUTH_AUDIENCE=your-m2m-audience

# Microservice Configuration
# Query service endpoint — get from 1Password
LFX_V2_SERVICE=your-query-service-url

# Supabase Database Configuration
# Get these from your Supabase project settings
# Used for user profile email management
SUPABASE_URL=https://your-project.supabase.co
POSTGRES_API_KEY=your-supabase-anon-key

# NATS Configuration
# Get from 1Password (LFX One Dev Environment vault)
NATS_URL=your-nats-url

############### SNOWFLAKE CONFIG ###############
# Snowflake Connection Configuration
# Used for analytics endpoints: active-weeks-streak, pull-requests-merged, code-commits
# Account identifier in format: orgname-accountname (e.g., jnmhvwd-xpb85243)
SNOWFLAKE_ACCOUNT=your-org-account
# Service user for read-only analytical queries
SNOWFLAKE_USER=your-username
# Warehouse for query execution
SNOWFLAKE_WAREHOUSE=your-warehouse
# Analytics database name
SNOWFLAKE_DATABASE=your-database
# User role with SELECT-only permissions
SNOWFLAKE_ROLE=your-read-role

# Snowflake Authentication (choose one method)
# Method 1: Direct API Key (recommended for containers/Docker)
# IMPORTANT: Must be the UNENCRYPTED private key (not passphrase-protected)
# SNOWFLAKE_API_KEY=your-unencrypted-private-key-here

# Method 2: Private Key File (recommended for local development)
# Place rsa_key.p8 file in this directory (same location as .env)
# The service will automatically detect and use it
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=your-passphrase-here

# Optional: Connection Pool Configuration (defaults shown)
# SNOWFLAKE_MIN_CONNECTIONS=2
# SNOWFLAKE_MAX_CONNECTIONS=10
# SNOWFLAKE_MAX_WAITING_CLIENTS=10

# Optional: Snowflake SDK Log Level (defaults to 'ERROR')
# SNOWFLAKE_LOG_LEVEL=ERROR

# Optional: Lock Strategy for Query Deduplication (defaults to 'memory')
# SNOWFLAKE_LOCK_STRATEGY=memory
############### END SNOWFLAKE CONFIG ###############

# Profile Client (Flow C) — second OIDC client for Auth0 Management API access
# See: lfx-v2-auth-service docs/auth-flows/C-profile-update.md
PROFILE_CLIENT_ID=your-profile-client-id
PROFILE_CLIENT_SECRET=your-profile-client-secret
PROFILE_AUDIENCE=https://linuxfoundation-dev.auth0.com/api/v2/
PROFILE_SCOPE="update:current_user_metadata update:current_user_identities"
# Profile redirect URI — defaults to ${PCC_BASE_URL}/passwordless/callback if not set
# Only override if Auth0 Profile Client has a different callback URL registered
# PROFILE_REDIRECT_URI=http://localhost:4200/passwordless/callback

# Impersonation — no additional env vars needed
# Token exchange and profile enrichment both go through NATS (lfx-v2-auth-service)

# Social identity connection redirect URI
# Used for GitHub/LinkedIn identity verification via Auth0 social connections
# Defaults to ${PCC_BASE_URL}/social/callback if not set
# SOCIAL_REDIRECT_URI=http://localhost:4200/social/callback

# CDP (Community Data Platform) Configuration
# Uses M2M token with CDP audience for server-to-server API access
CDP_API_URL=https://lf-staging.crowd.dev/api
CDP_AUDIENCE=https://lf-staging.crowd.dev/api/

# AI Service Configuration
# OpenAI-compatible proxy for meeting agenda generation
AI_PROXY_URL=https://litellm.tools.lfx.dev/chat/completions
AI_API_KEY=your-litellm-ai-api-key

# Thought Industries (TI) API Configuration
# Used to enrich course logo URLs for training certifications and enrollments.
# When absent, logo enrichment is skipped and courses fall back to the generic icon.
# Obtain from the TI admin dashboard (or 1Password — LFX One Dev Environment vault).
TI_API_KEY=

# LFX Lens (AI Data Assistant) Configuration
# API endpoint for the LFX Lens workflow agent
LENS_API_URL=https://lfx-ai.onrender.com
LENS_API_KEY=your-lens-api-key

# Runtime Client IDs
# These are injected at container runtime (not build time)
# allowing a single Docker image to be deployed to any environment

# LaunchDarkly Feature Flags
# Client-side ID for feature flag evaluation (publicly-publishable)
LD_CLIENT_ID=your-launchdarkly-client-id

# DataDog RUM Browser Monitoring (future integration)
# Client token and application ID for browser monitoring
DD_RUM_CLIENT_ID=your-datadog-rum-client-token
DD_RUM_APPLICATION_ID=your-datadog-rum-application-id

# E2E Test Configuration (Optional)
# Test user credentials for automated testing
TEST_USERNAME=your-test-username
TEST_PASSWORD=your-test-password

# Log Level (default: info)
# Set to 'debug' for verbose logging during development

LOG_LEVEL=info

API_GW_AUDIENCE=https://api-gw.dev.platform.linuxfoundation.org/

# Credly Badges Configuration
CREDLY_API_URL=https://api.credly.com/v1
CREDLY_ORG_ID=your-credly-org-id
CREDLY_API_TOKEN=your-credly-api-token

# Web Push (PWA notifications)
# Generate locally with:
#   node -e "const k=require('web-push').generateVAPIDKeys();console.log(k)"
# Both keys must match — rotating either invalidates every existing
# subscription. VAPID_PUBLIC_KEY is exposed to the browser at runtime;
# VAPID_PRIVATE_KEY MUST stay server-side.
VAPID_SUBJECT=mailto:dev@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Local-only file-backed store for PWA push subscriptions (research / dev).
# Defaults to apps/lfx-one/.local-data/push-subscriptions.json. Production
# deployments should swap this for Supabase or another durable store.
PUSH_SUBSCRIPTIONS_FILE=
