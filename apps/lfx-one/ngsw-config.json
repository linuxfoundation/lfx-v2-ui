{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "navigationUrls": ["/**", "!/**/*.*", "!/**/*__*", "!/**/*__*/**", "!/api/**", "!/callback", "!/login", "!/logout", "!/.well-known/**"],
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/favicon.ico", "/manifest.webmanifest", "/index.html", "/*.css", "/*.js"]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/icons/**", "/images/**", "/media/**", "/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-user-readonly",
      "urls": ["/api/user/personas", "/api/user/personas?*", "/api/nav/lens-items", "/api/nav/lens-items?*", "/api/profile", "/api/profile?*"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 30,
        "maxAge": "1h",
        "timeout": "3s",
        "cacheOpaqueResponses": false
      }
    },
    {
      "name": "api-user-dashboard",
      "urls": ["/api/user/pending-actions", "/api/user/pending-actions?*", "/api/user/meetings", "/api/user/meetings?*"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 20,
        "maxAge": "15m",
        "timeout": "3s",
        "cacheOpaqueResponses": false
      }
    }
  ]
}
