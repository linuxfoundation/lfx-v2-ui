{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lfx.dev/schemas/docs-manifest.schema.json",
  "title": "DocsManifest",
  "description": "Build artifact emitted by apps/lfx-one/scripts/build-docs.mjs. Drives runtime rendering of /docs/** and the /sitemap.xml endpoint. Schema-versioned; runtime refuses to load on schemaVersion mismatch.",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "contentHash", "topics", "articles", "tree", "sourcePathToSlug"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1,
      "description": "Bumped on incompatible manifest shape changes."
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp when the manifest was generated."
    },
    "contentHash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "SHA-256 hex digest of the concatenated source markdown files. Used by CI to detect content drift without re-running the full build."
    },
    "topics": {
      "type": "array",
      "description": "Topics in canonical display order. One entry per top-level subdirectory of docs/user/.",
      "items": { "$ref": "#/$defs/DocsTopic" }
    },
    "articles": {
      "type": "object",
      "description": "Flat lookup table mapping slug to article. Includes the synthetic root landing under the empty-string key.",
      "patternProperties": {
        "^([a-z0-9]+(?:-[a-z0-9]+)*(?:/[a-z0-9]+(?:-[a-z0-9]+)*)*)?$": { "$ref": "#/$defs/DocsArticle" }
      },
      "additionalProperties": false
    },
    "tree": {
      "$ref": "#/$defs/DocsTaxonomyNode",
      "description": "Recursive taxonomy tree rooted at the synthetic root (slug='')."
    },
    "sourcePathToSlug": {
      "type": "object",
      "description": "Lookup table for the build-time link rewriter and CI completeness checks: source path -> slug.",
      "patternProperties": {
        "^docs/user/.*\\.md$": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "DocsArticle": {
      "type": "object",
      "required": [
        "slug",
        "url",
        "sourcePath",
        "topic",
        "title",
        "description",
        "bodyHtml",
        "headings",
        "bodyText",
        "lastUpdated",
        "breadcrumb",
        "siblings",
        "isTopicLanding"
      ],
      "additionalProperties": false,
      "properties": {
        "slug": {
          "type": "string",
          "pattern": "^([a-z0-9]+(?:-[a-z0-9]+)*(?:/[a-z0-9]+(?:-[a-z0-9]+)*)*)?$",
          "description": "Lowercase kebab segments separated by /. Empty string for the root landing."
        },
        "url": {
          "type": "string",
          "pattern": "^/docs(/[a-z0-9]+(?:-[a-z0-9]+)*(?:/[a-z0-9]+(?:-[a-z0-9]+)*)*)?$",
          "description": "Public URL path. Always starts with /docs, no trailing slash."
        },
        "sourcePath": {
          "type": "string",
          "pattern": "^(docs/user/.*/index\\.md)?$",
          "description": "Markdown source file path, relative to repo root. Empty string for the synthetic root landing (no backing markdown file)."
        },
        "topic": { "type": "string" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "bodyHtml": {
          "type": "string",
          "description": "Sanitized HTML body. Output of marked -> link rewriter -> sanitize-html."
        },
        "bodyText": {
          "type": "string",
          "description": "Plain-text body (HTML stripped). Used by the search indexer and as a description fallback."
        },
        "headings": {
          "type": "array",
          "items": { "$ref": "#/$defs/DocsHeading" }
        },
        "audience": {
          "type": "array",
          "items": {
            "enum": ["all", "contributor", "maintainer", "board-member", "executive-director"]
          }
        },
        "productArea": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "intercomCollection": { "type": "string" },
        "lastUpdated": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "ISO date (YYYY-MM-DD)."
        },
        "breadcrumb": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/DocsBreadcrumbItem" }
        },
        "siblings": {
          "type": "array",
          "items": { "type": "string" }
        },
        "isTopicLanding": { "type": "boolean" },
        "displayOrder": { "type": "integer", "minimum": 0 }
      }
    },
    "DocsHeading": {
      "type": "object",
      "required": ["level", "text", "id"],
      "additionalProperties": false,
      "properties": {
        "level": { "type": "integer", "minimum": 1, "maximum": 6 },
        "text": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" }
      }
    },
    "DocsBreadcrumbItem": {
      "type": "object",
      "required": ["slug", "title", "url"],
      "additionalProperties": false,
      "properties": {
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "url": { "type": "string" }
      }
    },
    "DocsTopic": {
      "type": "object",
      "required": ["slug", "name", "description", "displayOrder", "landingSlug", "articleSlugs"],
      "additionalProperties": false,
      "properties": {
        "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "displayOrder": { "type": "integer", "minimum": 0 },
        "icon": { "type": "string" },
        "landingSlug": { "type": "string" },
        "articleSlugs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        }
      }
    },
    "DocsTaxonomyNode": {
      "type": "object",
      "required": ["slug", "title", "url", "children"],
      "additionalProperties": false,
      "properties": {
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "url": { "type": "string" },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/DocsTaxonomyNode" }
        }
      }
    }
  }
}
