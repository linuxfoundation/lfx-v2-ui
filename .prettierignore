# Ignore everything
*.*

# Email + PDF templates use mustache placeholders that prettier can't parse as Angular HTML
apps/lfx-one/src/server/pdf-templates/
apps/lfx-one/src/server/email-templates/

# Ignore test and build artifacts
playwright-report/
test-results/
dist/
node_modules/
.angular/

# Docs portal — build artifacts (regenerated by scripts/build-docs.mjs via yarn docs:build)
apps/lfx-one/dist-docs/
apps/lfx-one/src/app/modules/docs/generated/
apps/lfx-one/public/assets/docs/

# Include .claude directory (Prettier 3.x ignores dot-directories by default)
!.claude/

# Don't ignore these file types
!*.html
!*.tsx
!*.ts
!*.js
!*.jsx
!*.json
!*.css
!*.scss
!*.md
!*.mdx
